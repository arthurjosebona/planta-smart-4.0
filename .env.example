# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de rodar o Docker.
# O .env NÃO deve ser commitado (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL base do backend consumida pelo frontend (injetada em build-time pelo Vite)
VITE_BASE_URL=http://localhost:8080

# ── Backend ──────────────────────────────────────────────────────────────────
# Porta em que o Spring Boot sobe (padrão 8080)
PORT=8080

# Credenciais do banco de dados MySQL
DB_USER=root
DB_PASSWORD=senha_aqui

# ── Banco de dados ────────────────────────────────────────────────────────────
# Senha do root do MySQL (usada pelo container mysql)
MYSQL_ROOT_PASSWORD=senha_aqui
MYSQL_DATABASE=db_sa_smart40
